{
  "name": "note",
  "description": "A minimal html editor",
  "type": "module",
  "main": "src/note.mjs",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "build-dev": "./node_modules/.bin/esbuild --loader:.css=text src/notebook.mjs --bundle --format=esm --sourcemap --outfile=www/app.js",
    "build": "./node_modules/.bin/esbuild --loader:.css=text src/notebook.mjs --bundle --format=esm --sourcemap --outfile=www/app.min.js --minify",
    "dev": "watch 'npm run build-dev' ./src & npx http-server www/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/poef/note.git"
  },
  "author": "auke@muze.nl",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/poef/note/issues"
  },
  "homepage": "https://github.com/poef/note/#readme",
  "devDependencies": {
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "jest": "^30.4.2",
    "watch": "^1.0.2"
  },
  "dependencies": {
    "@muze-nl/metro": "^0.7.1",
    "@muze-nl/theds": "^0.2.7",
    "note": "file:../note/",
    "simplyflow": "file:../../simplyedit/simplyflow/",
    "simplyview": "^3.5.9",
    "@muze-nl/helene": "file:../../muze-nl/helene/"
  }
}
